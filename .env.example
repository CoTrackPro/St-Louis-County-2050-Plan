# ─────────────────────────────────────────────────────────────────────────────
# CoTrackPro — Environment Variables
# Copy to .env.local for local dev, then run: npm run secrets
# All SecureString values are pulled from AWS SSM Parameter Store
# ─────────────────────────────────────────────────────────────────────────────

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=CoTrackPro
NEXT_PUBLIC_URL=http://localhost:3000
APP_ENVIRONMENT=development

# ─── Security (generate with: openssl rand -hex 32) ───────────────────────────
JWT_SECRET=
ENCRYPTION_KEY=
SESSION_SECRET=

# ─── Clerk (https://dashboard.clerk.com → API Keys) ───────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/billing

# ─── Stripe (https://dashboard.stripe.com) ────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe — Product IDs (Dashboard → Products)
STRIPE_PRODUCT_PARENT=prod_...
STRIPE_PRODUCT_PROFESSIONAL=prod_...

# Stripe — Price IDs (Dashboard → Products → Prices)
STRIPE_PRICE_PARENT_MONTHLY=price_...
STRIPE_PRICE_PARENT_ANNUAL=price_...
STRIPE_PRICE_PROFESSIONAL_MONTHLY=price_...
STRIPE_PRICE_PROFESSIONAL_ANNUAL=price_...

# ─── AWS SES (IAM user with ses:SendEmail permission) ─────────────────────────
SES_FROM_ADDRESS=CoTrackPro <admin@cotrackpro.com>
SES_AWS_ACCESS_KEY_ID=AKIA...
SES_AWS_SECRET_ACCESS_KEY=

# ─── AI Provider (anthropic | openai | gemini) ────────────────────────────────
AI_DEFAULT_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# ─── ElevenLabs (https://elevenlabs.io → Profile) ─────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ─── Mailchimp (https://mailchimp.com → Account → API Keys) ───────────────────
MAILCHIMP_API_KEY=

# ─── Infrastructure ───────────────────────────────────────────────────────────
S3_ASSETS_BUCKET=cotrackpro-assets
DYNAMODB_USERS_TABLE=cotrackpro-users

# ─── Monitoring — Highlight.io (https://app.highlight.io) ─────────────────────
# Free tier: unlimited errors, 500 sessions/mo, open source
HIGHLIGHT_PROJECT_ID=
NEXT_PUBLIC_HIGHLIGHT_PROJECT_ID=

# ─── MCP Server (optional — leave blank for mock mode in development) ─────────
MCP_SERVER_URL=
MCP_API_KEY=
